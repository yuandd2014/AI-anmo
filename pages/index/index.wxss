/* ===== 全局 ===== */
page {
  background: linear-gradient(180deg, #FFF5F0 0%, #FFE8E0 50%, #FFDDD0 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 48rpx 80rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 顶部标题 ===== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 40rpx;
}

.heart-icon {
  font-size: 64rpx;
  color: #E8575A;
  margin-bottom: 12rpx;
  animation: heartbeat 1.5s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #5C4033;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #C4A08A;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* ===== 设置卡片 ===== */
.setup-card {
  width: 100%;
  background: rgba(255,255,255,0.85);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(232,87,90,0.12);
  backdrop-filter: blur(10px);
}

.input-group {
  margin-bottom: 40rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #8B6F5E;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-row {
  display: flex;
  align-items: center;
  background: #FFF8F5;
  border: 2rpx solid #F0D5C8;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}

.input-field {
  flex: 1;
  height: 48rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #5C4033;
  caret-color: #E8575A;
}

.input-field::placeholder {
  color: #D4C0B4;
  font-weight: 400;
  font-size: 30rpx;
}

.input-unit {
  font-size: 28rpx;
  color: #C4A08A;
  margin-left: 12rpx;
  white-space: nowrap;
}

/* ===== 按钮 ===== */
.btn-primary {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #E8575A, #D44A4D);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  margin-top: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(232,87,90,0.35);
}

.btn-primary[disabled] {
  background: #E8D5CC;
  box-shadow: none;
  color: #B8A090;
}

.btn-start {
  width: 80%;
  height: 112rpx;
  line-height: 112rpx;
  background: linear-gradient(135deg, #E8575A, #D44A4D);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 56rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(232,87,90,0.4);
  margin-top: 40rpx;
  letter-spacing: 4rpx;
}

.btn-start:active {
  transform: scale(0.96);
}

.btn-stop {
  width: 70%;
  height: 100rpx;
  line-height: 100rpx;
  background: #FFF8F5;
  color: #E8575A;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 50rpx;
  border: 3rpx solid #E8575A;
  margin-top: 60rpx;
  letter-spacing: 2rpx;
}

.btn-stop:active {
  background: #FFF0E8;
}

.btn-back {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #C4A08A;
  text-decoration: underline;
  padding: 12rpx 24rpx;
}

/* ===== 准备状态 ===== */
.info-card {
  width: 100%;
  background: rgba(255,255,255,0.85);
  border-radius: 24rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(232,87,90,0.08);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 30rpx;
  color: #8B6F5E;
}

.info-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #E8575A;
}

.info-divider {
  height: 2rpx;
  background: #F0D5C8;
  margin: 8rpx 0;
}

.big-number {
  font-size: 32rpx;
  color: #C4A08A;
  text-align: center;
  margin-top: 60rpx;
}

/* ===== 计时状态 ===== */
.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
}

.timer-text {
  font-size: 120rpx;
  font-weight: 300;
  color: #5C4033;
  letter-spacing: 8rpx;
  font-variant-numeric: tabular-nums;
}

.timer-label {
  font-size: 26rpx;
  color: #C4A08A;
  margin-top: 8rpx;
}

.cost-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: 60rpx;
}

.cost-amount {
  font-size: 96rpx;
  font-weight: 700;
  color: #E8575A;
  font-variant-numeric: tabular-nums;
}

.cost-unit {
  font-size: 32rpx;
  color: #C4A08A;
  margin-left: 8rpx;
}

.cost-tip {
  font-size: 24rpx;
  color: #D4C0B4;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ===== 结果状态 ===== */
.result-card {
  width: 100%;
  background: rgba(255,255,255,0.9);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(232,87,90,0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

.result-heart {
  font-size: 72rpx;
  color: #E8575A;
  margin-bottom: 12rpx;
  animation: heartbeat 1.5s ease-in-out infinite;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5C4033;
  margin-bottom: 36rpx;
}

.result-details {
  width: 100%;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
}

.result-item-label {
  font-size: 28rpx;
  color: #8B6F5E;
}

.result-item-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C4033;
}

.result-item-value-big {
  font-size: 48rpx;
  font-weight: 800;
  color: #E8575A;
}

.result-remark {
  font-size: 24rpx;
  color: #C4A08A;
  text-align: center;
  padding: 8rpx 0;
  font-style: italic;
}

.result-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #F0D5C8, transparent);
  margin: 16rpx 0;
}

.result-total {
  padding-top: 20rpx;
}

.result-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
}
